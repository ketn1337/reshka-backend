#!/bin/sh
# Validates that the commit message follows Conventional Commits.
# Allowed types: feat, fix, chore, docs, refactor, style, test, ci, build, perf, revert
#
# Skip this hook for merge / revert / fixup / squash commits produced by Git itself.

set -e

commit_msg_file="$1"
first_line=$(head -n1 "$commit_msg_file")

case "$first_line" in
  "Merge "* | "Revert "* | "fixup! "* | "squash! "* | "amend! "*)
    exit 0
    ;;
esac

# type(scope)?!: subject  — subject must be non-empty and ≤ 100 chars
pattern='^(feat|fix|chore|docs|refactor|style|test|ci|build|perf|revert)(\([a-zA-Z0-9._/-]+\))?!?: .+$'

if ! printf '%s' "$first_line" | grep -qE "$pattern"; then
  echo ""
  echo "✗ Commit message does not follow Conventional Commits."
  echo ""
  echo "  First line: $first_line"
  echo ""
  echo "  Expected:   <type>(<optional-scope>): <subject>"
  echo ""
  echo "  Allowed types: feat, fix, chore, docs, refactor, style, test, ci, build, perf, revert"
  echo ""
  echo "  Examples:"
  echo "    feat: add booking grid scroll"
  echo "    fix(auth): correct jwt expiration"
  echo "    chore: bump gin to v1.10.0"
  echo ""
  exit 1
fi

if [ ${#first_line} -gt 100 ]; then
  echo ""
  echo "✗ Commit subject is longer than 100 characters (${#first_line})."
  echo "  Keep it short — details belong in the body."
  echo ""
  exit 1
fi

exit 0
